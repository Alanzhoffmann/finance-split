@page "/transactions"
@using FinanceSplit.Contracts.Enums
@using FinanceSplit.Contracts.Requests
@using FinanceSplit.Contracts.Responses
@using FinanceSplit.Web.Services
@inject ApiClient Api
@inject ISnackbar Snackbar

<PageTitle>Transactions</PageTitle>

<MudText Typo="Typo.h4" Class="mb-4">Transactions</MudText>

<MudPaper Class="pa-4" Elevation="1">
    <MudText Typo="Typo.h6" Class="mb-3">Create Transaction</MudText>
    <MudGrid>
        <MudItem xs="12" sm="6">
            <MudTextField @bind-Value="Title" Label="Title" Required="true"
                          RequiredError="Title is required" Variant="Variant.Outlined" />
        </MudItem>
        <MudItem xs="12" sm="6">
            <MudNumericField @bind-Value="Amount" Label="Amount" Format="N2"
                             Min="0.01m" Variant="Variant.Outlined"
                             Adornment="Adornment.Start" AdornmentText="$" />
        </MudItem>
        <MudItem xs="12" sm="6">
            <MudSelect @bind-Value="PaidById" Label="Paid By" Variant="Variant.Outlined"
                       AnchorOrigin="Origin.BottomCenter" T="Guid">
                @foreach (var person in People)
                {
                    <MudSelectItem Value="@person.Id">@person.Name</MudSelectItem>
                }
            </MudSelect>
        </MudItem>
        <MudItem xs="12" sm="6">
            <MudSelect @bind-Value="SelectedSplitType" Label="Split Type" Variant="Variant.Outlined"
                       AnchorOrigin="Origin.BottomCenter" T="SplitType">
                <MudSelectItem Value="SplitType.Even">
                    <MudTooltip Text="Split evenly among all participants" Placement="Placement.Right">
                        <ChildContent>Even</ChildContent>
                    </MudTooltip>
                </MudSelectItem>
                <MudSelectItem Value="SplitType.Ratio">
                    <MudTooltip Text="Split proportionally by salary" Placement="Placement.Right">
                        <ChildContent>Ratio (by salary)</ChildContent>
                    </MudTooltip>
                </MudSelectItem>
                <MudSelectItem Value="SplitType.None">
                    <MudTooltip Text="One person pays entirely" Placement="Placement.Right">
                        <ChildContent>None (personal)</ChildContent>
                    </MudTooltip>
                </MudSelectItem>
            </MudSelect>
        </MudItem>
        <MudItem xs="12">
            <MudText Typo="Typo.subtitle1" Class="mb-2">Participants</MudText>
            <MudChipSet T="string" SelectionMode="SelectionMode.MultiSelection" @bind-SelectedValues="_selectedChips" CheckMark="true" Color="Color.Primary" Variant="Variant.Text">
                @foreach (var person in People)
                {
                    <MudChip Text="@person.Name" Value="@person.Id.ToString()" />
                }
            </MudChipSet>
        </MudItem>
        <MudItem xs="12">
            <MudButton Variant="Variant.Filled" Color="Color.Primary"
                       StartIcon="@Icons.Material.Filled.Add" OnClick="CreateTransaction">
                Create Transaction
            </MudButton>
        </MudItem>
    </MudGrid>
</MudPaper>

@code {
    private IReadOnlyList<PersonResponse> People { get; set; } = [];
    private string Title { get; set; } = string.Empty;
    private decimal Amount { get; set; }
    private Guid PaidById { get; set; }
    private SplitType SelectedSplitType { get; set; } = SplitType.Even;
    private IReadOnlyCollection<string> _selectedChips = [];

    protected override async Task OnInitializedAsync()
    {
        People = await Api.GetPeopleAsync();
        if (People.Count > 0)
        {
            PaidById = People[0].Id;
            _selectedChips = People.Select(p => p.Id.ToString()).ToList();
        }
    }

    private async Task CreateTransaction()
    {
        if (string.IsNullOrWhiteSpace(Title) || Amount <= 0) return;

        var participantIds = _selectedChips.Select(Guid.Parse).ToList();

        var request = new CreateTransactionRequest(
            Title, Amount, PaidById, SelectedSplitType, participantIds, DateTime.UtcNow);

        var result = await Api.CreateTransactionAsync(request);

        if (result is not null)
        {
            Snackbar.Add($"Transaction '{result.Title}' created", Severity.Success);
            Title = string.Empty;
            Amount = 0;
        }
        else
        {
            Snackbar.Add("Failed to create transaction", Severity.Error);
        }
    }
}
