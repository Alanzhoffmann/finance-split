@page "/transactions"
@using FinanceSplit.Contracts.Enums
@using FinanceSplit.Contracts.Requests
@using FinanceSplit.Contracts.Responses
@using FinanceSplit.Web.Services
@inject ApiClient Api
@inject IDialogService DialogService
@inject ISnackbar Snackbar

<PageTitle>Transactions</PageTitle>

<MudText Typo="Typo.h4" Class="mb-4">Transactions</MudText>

<MudPaper Class="pa-4 mb-4" Elevation="1">
    <MudGrid>
        <MudItem xs="12" sm="6" md="4">
            <MudDatePicker Label="Month" @bind-Date="_selectedDate" @bind-Date:after="LoadTransactions"
                           OpenTo="OpenTo.Month" FixDay="1" DateFormat="yyyy-MM" Variant="Variant.Outlined" />
        </MudItem>
        <MudItem xs="12" sm="6" md="4" Class="d-flex align-end">
            <MudButton Variant="Variant.Filled" Color="Color.Primary"
                       StartIcon="@Icons.Material.Filled.Add" OnClick="OpenCreateDialog">
                New Transaction
            </MudButton>
        </MudItem>
    </MudGrid>
</MudPaper>

@if (MonthTransactions.Count > 0)
{
    <MudTable Items="MonthTransactions" Hover="true" Striped="true" Elevation="1" Dense="true">
        <HeaderContent>
            <MudTh>Title</MudTh>
            <MudTh>Amount</MudTh>
            <MudTh>Paid By</MudTh>
            <MudTh>Split</MudTh>
            <MudTh>Actions</MudTh>
        </HeaderContent>
        <RowTemplate>
            <MudTd DataLabel="Title">
                <MudText Typo="Typo.body1">@context.Title</MudText>
            </MudTd>
            <MudTd DataLabel="Amount">
                <MudText Typo="Typo.body2" Color="Color.Primary"><strong>@context.Amount.ToString("C")</strong></MudText>
            </MudTd>
            <MudTd DataLabel="Paid By">
                <MudChip T="string" Color="Color.Info" Size="Size.Small">@context.PaidBy.Name</MudChip>
            </MudTd>
            <MudTd DataLabel="Split">
                <MudTooltip Text="@string.Join(", ", context.SplitParticipants.Select(p => p.Name))">
                    <MudChip T="string" Color="Color.Default" Size="Size.Small">
                        @context.SplitType (@context.SplitParticipants.Count)
                    </MudChip>
                </MudTooltip>
            </MudTd>
            <MudTd DataLabel="Actions">
                <MudTooltip Text="Edit transaction">
                    <MudIconButton Icon="@Icons.Material.Filled.Edit" Color="Color.Primary"
                                   Size="Size.Small" OnClick="() => OpenEditDialog(context)" />
                </MudTooltip>
            </MudTd>
        </RowTemplate>
    </MudTable>
}
else if (HasLoaded)
{
    <MudAlert Severity="Severity.Info" Class="mt-4">No transactions for this month.</MudAlert>
}

@code {
    private DateTime? _selectedDate = new DateTime(DateTime.UtcNow.Year, DateTime.UtcNow.Month, 1);
    private DateOnly SelectedMonth => _selectedDate.HasValue
        ? new DateOnly(_selectedDate.Value.Year, _selectedDate.Value.Month, 1)
        : new DateOnly(DateTime.UtcNow.Year, DateTime.UtcNow.Month, 1);
    private IReadOnlyList<PersonResponse> People { get; set; } = [];
    private IReadOnlyCollection<TransactionResponse> MonthTransactions { get; set; } = [];
    private bool HasLoaded { get; set; }

    protected override async Task OnInitializedAsync()
    {
        People = await Api.GetPeopleAsync();
        await LoadTransactions();
    }

    private async Task LoadTransactions()
    {
        var summary = await Api.GetMonthlySummaryAsync(SelectedMonth);
        MonthTransactions = summary?.Transactions ?? [];
        HasLoaded = true;
    }

    private async Task OpenCreateDialog()
    {
        var parameters = new DialogParameters<TransactionDialog>
        {
            { x => x.People, People },
        };

        var options = new DialogOptions { CloseOnEscapeKey = true, MaxWidth = MaxWidth.Medium, FullWidth = true };
        var dialog = await DialogService.ShowAsync<TransactionDialog>("New Transaction", parameters, options);
        var result = await dialog.Result;

        if (result is not null && !result.Canceled)
        {
            await LoadTransactions();
        }
    }

    private async Task OpenEditDialog(TransactionResponse transaction)
    {
        var parameters = new DialogParameters<TransactionDialog>
        {
            { x => x.People, People },
            { x => x.Transaction, transaction },
        };

        var options = new DialogOptions { CloseOnEscapeKey = true, MaxWidth = MaxWidth.Medium, FullWidth = true };
        var dialog = await DialogService.ShowAsync<TransactionDialog>($"Edit: {transaction.Title}", parameters, options);
        var result = await dialog.Result;

        if (result is not null && !result.Canceled)
        {
            await LoadTransactions();
        }
    }
}
