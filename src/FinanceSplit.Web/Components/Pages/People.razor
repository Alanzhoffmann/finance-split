@page "/people"
@using FinanceSplit.Contracts.Responses
@using FinanceSplit.Web.Services
@inject ApiClient Api
@inject IDialogService DialogService
@inject ISnackbar Snackbar

<PageTitle>People</PageTitle>

<MudText Typo="Typo.h4" Class="mb-4">People</MudText>

<MudPaper Class="pa-4 mb-4" Elevation="1">
    <MudText Typo="Typo.h6" Class="mb-2">Add Person</MudText>
    <MudForm @ref="_addPersonForm">
        <MudGrid>
            <MudItem xs="12" sm="8">
                <MudTextField @bind-Value="NewPersonName" Label="Name" Placeholder="Enter name"
                              Required="true" RequiredError="Name is required"
                              Variant="Variant.Outlined" />
            </MudItem>
            <MudItem xs="12" sm="4" Class="d-flex align-end">
                <MudButton Variant="Variant.Filled" Color="Color.Primary"
                           StartIcon="@Icons.Material.Filled.PersonAdd" OnClick="AddPerson">
                    Add
                </MudButton>
            </MudItem>
        </MudGrid>
    </MudForm>
</MudPaper>

@if (AllPeople.Count > 0)
{
    <MudTable Items="AllPeople" Hover="true" Striped="true" Elevation="1" Dense="true">
        <HeaderContent>
            <MudTh>Name</MudTh>
            <MudTh>Current Salary</MudTh>
            <MudTh>Salary History</MudTh>
            <MudTh>Actions</MudTh>
        </HeaderContent>
        <RowTemplate>
            <MudTd DataLabel="Name">
                @if (_editingPersonId == context.Id)
                {
                    <MudTextField @bind-Value="_editingName" Variant="Variant.Text" Margin="Margin.Dense"
                                  Immediate="true" OnKeyDown="OnEditKeyDown" />
                }
                else
                {
                    <MudText Typo="Typo.body1">@context.Name</MudText>
                }
            </MudTd>
            <MudTd DataLabel="Current Salary">
                @{
                    var latestSalary = context.Salaries.OrderByDescending(s => s.Date).FirstOrDefault();
                }
                <MudText Typo="Typo.body2">
                    @(latestSalary is not null ? latestSalary.Amount.ToString("C") : "Not set")
                </MudText>
            </MudTd>
            <MudTd DataLabel="Salary History">
                @if (context.Salaries.Any())
                {
                    <MudTooltip>
                        <ChildContent>
                            <MudChip T="string" Color="Color.Info" Size="Size.Small">@context.Salaries.Count entries</MudChip>
                        </ChildContent>
                        <TooltipContent>
                            @foreach (var s in context.Salaries.OrderByDescending(s => s.Date))
                            {
                                <MudText Typo="Typo.caption">@s.Date.ToString("yyyy-MM"): @s.Amount.ToString("C")</MudText><br />
                            }
                        </TooltipContent>
                    </MudTooltip>
                }
                else
                {
                    <MudText Typo="Typo.body2" Color="Color.Warning">No salary records</MudText>
                }
            </MudTd>
            <MudTd DataLabel="Actions">
                @if (_editingPersonId == context.Id)
                {
                    <MudTooltip Text="Save name">
                        <MudIconButton Icon="@Icons.Material.Filled.Check" Color="Color.Success"
                                       Size="Size.Small" OnClick="SaveName" />
                    </MudTooltip>
                    <MudTooltip Text="Cancel">
                        <MudIconButton Icon="@Icons.Material.Filled.Close" Color="Color.Default"
                                       Size="Size.Small" OnClick="CancelEditName" />
                    </MudTooltip>
                }
                else
                {
                    <MudTooltip Text="Edit name">
                        <MudIconButton Icon="@Icons.Material.Filled.DriveFileRenameOutline" Color="Color.Warning"
                                       Size="Size.Small" OnClick="() => StartEditName(context)" />
                    </MudTooltip>
                }
                <MudTooltip Text="Add salary record">
                    <MudIconButton Icon="@Icons.Material.Filled.AttachMoney" Color="Color.Success"
                                   Size="Size.Small" OnClick="() => OpenSalaryDialog(context)" />
                </MudTooltip>
                @if (context.Salaries.Any())
                {
                    <MudTooltip Text="Edit latest salary">
                        <MudIconButton Icon="@Icons.Material.Filled.Edit" Color="Color.Primary"
                                       Size="Size.Small" OnClick="() => OpenEditSalaryDialog(context)" />
                    </MudTooltip>
                }
            </MudTd>
        </RowTemplate>
    </MudTable>
}

@code {
    private MudForm? _addPersonForm;
    private IReadOnlyList<PersonResponse> AllPeople { get; set; } = [];
    private string NewPersonName { get; set; } = string.Empty;
    private Guid? _editingPersonId;
    private string _editingName = string.Empty;

    protected override async Task OnInitializedAsync()
    {
        AllPeople = await Api.GetPeopleAsync();
    }

    private async Task AddPerson()
    {
        if (string.IsNullOrWhiteSpace(NewPersonName)) return;

        await Api.CreatePersonAsync(NewPersonName);
        Snackbar.Add($"Added {NewPersonName}", Severity.Success);
        NewPersonName = string.Empty;
        AllPeople = await Api.GetPeopleAsync();
    }

    private void StartEditName(PersonResponse person)
    {
        _editingPersonId = person.Id;
        _editingName = person.Name;
    }

    private void CancelEditName()
    {
        _editingPersonId = null;
        _editingName = string.Empty;
    }

    private async Task SaveName()
    {
        if (_editingPersonId is null || string.IsNullOrWhiteSpace(_editingName)) return;

        await Api.UpdatePersonNameAsync(_editingPersonId.Value, _editingName);
        Snackbar.Add("Name updated", Severity.Success);
        _editingPersonId = null;
        _editingName = string.Empty;
        AllPeople = await Api.GetPeopleAsync();
    }

    private async Task OnEditKeyDown(KeyboardEventArgs e)
    {
        if (e.Key == "Enter")
            await SaveName();
        else if (e.Key == "Escape")
            CancelEditName();
    }

    private async Task OpenSalaryDialog(PersonResponse person)
    {
        var parameters = new DialogParameters<SalaryDialog>
        {
            { x => x.PersonId, person.Id },
            { x => x.PersonName, person.Name },
        };

        var options = new DialogOptions { CloseOnEscapeKey = true, MaxWidth = MaxWidth.Small, FullWidth = true };
        var dialog = await DialogService.ShowAsync<SalaryDialog>($"Add Salary for {person.Name}", parameters, options);
        var result = await dialog.Result;

        if (result is not null && !result.Canceled)
        {
            AllPeople = await Api.GetPeopleAsync();
        }
    }

    private async Task OpenEditSalaryDialog(PersonResponse person)
    {
        var latest = person.Salaries.OrderByDescending(s => s.Date).First();
        var parameters = new DialogParameters<SalaryDialog>
        {
            { x => x.PersonId, person.Id },
            { x => x.PersonName, person.Name },
            { x => x.ExistingDate, latest.Date },
            { x => x.ExistingAmount, latest.Amount },
        };

        var options = new DialogOptions { CloseOnEscapeKey = true, MaxWidth = MaxWidth.Small, FullWidth = true };
        var dialog = await DialogService.ShowAsync<SalaryDialog>($"Edit Salary for {person.Name}", parameters, options);
        var result = await dialog.Result;

        if (result is not null && !result.Canceled)
        {
            AllPeople = await Api.GetPeopleAsync();
        }
    }
}
