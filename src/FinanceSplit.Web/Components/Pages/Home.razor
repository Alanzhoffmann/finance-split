@page "/"
@using FinanceSplit.Contracts.Enums
@using FinanceSplit.Contracts.Responses
@using FinanceSplit.Web.Services
@inject ApiClient Api

<PageTitle>Finance Split</PageTitle>

<MudText Typo="Typo.h4" Class="mb-4">Dashboard</MudText>

<MudDatePicker Label="Month" @bind-Date="_selectedDate" @bind-Date:after="LoadData"
               OpenTo="OpenTo.Month" FixDay="1" DateFormat="yyyy-MM" Class="mb-4" Style="max-width: 200px;" />

@if (People.Count == 0)
{
    <MudAlert Severity="Severity.Info" Class="mt-4">
        No people added yet. <MudLink Href="/people">Add people</MudLink> to get started.
    </MudAlert>
}
else
{
    <MudGrid>
        @foreach (var person in People)
        {
            var salary = GetSalary(person);
            var personalExpenses = GetPersonalExpenses(person.Id);
            var sharedExpenses = GetSharedExpenses(person.Id);
            var leftover = salary - personalExpenses - sharedExpenses;

            <MudItem xs="12" sm="6" md="4">
                <MudCard Elevation="2" Class="person-card">
                    <MudCardHeader>
                        <CardHeaderContent>
                            <MudText Typo="Typo.h6">@person.Name</MudText>
                        </CardHeaderContent>
                        <CardHeaderActions>
                            <MudTooltip Text="Monthly financial overview">
                                <MudIconButton Icon="@Icons.Material.Filled.Info" Color="Color.Default" Size="Size.Small" />
                            </MudTooltip>
                        </CardHeaderActions>
                    </MudCardHeader>
                    <MudCardContent>
                        <MudSimpleTable Dense="true" Hover="true" Bordered="false">
                            <tbody>
                                <tr>
                                    <td><MudText Typo="Typo.body2">Salary</MudText></td>
                                    <td><MudText Typo="Typo.body2" Align="Align.End">@salary.ToString("C")</MudText></td>
                                </tr>
                                <tr>
                                    <td>
                                        <MudTooltip Text="Expenses paid solely by this person">
                                            <MudText Typo="Typo.body2">Personal Expenses</MudText>
                                        </MudTooltip>
                                    </td>
                                    <td><MudText Typo="Typo.body2" Align="Align.End" Color="Color.Warning">@personalExpenses.ToString("C")</MudText></td>
                                </tr>
                                <tr>
                                    <td>
                                        <MudTooltip Text="This person's share of shared expenses">
                                            <MudText Typo="Typo.body2">Shared Expenses</MudText>
                                        </MudTooltip>
                                    </td>
                                    <td><MudText Typo="Typo.body2" Align="Align.End" Color="Color.Info">@sharedExpenses.ToString("C")</MudText></td>
                                </tr>
                                <tr>
                                    <td><MudText Typo="Typo.body2"><strong>Leftover</strong></MudText></td>
                                    <td><MudText Typo="Typo.body2" Align="Align.End" Color="@(leftover >= 0 ? Color.Success : Color.Error)"><strong>@leftover.ToString("C")</strong></MudText></td>
                                </tr>
                            </tbody>
                        </MudSimpleTable>
                    </MudCardContent>
                </MudCard>
            </MudItem>
        }
    </MudGrid>
}

@code {
    private DateTime? _selectedDate = new DateTime(DateTime.UtcNow.Year, DateTime.UtcNow.Month, 1);
    private DateOnly SelectedMonth => _selectedDate.HasValue
        ? new DateOnly(_selectedDate.Value.Year, _selectedDate.Value.Month, 1)
        : new DateOnly(DateTime.UtcNow.Year, DateTime.UtcNow.Month, 1);
    private IReadOnlyList<PersonResponse> People { get; set; } = [];
    private MonthlyExpenseSummaryResponse? Summary { get; set; }

    protected override async Task OnInitializedAsync()
    {
        await LoadData();
    }

    private async Task LoadData()
    {
        People = await Api.GetPeopleAsync();
        Summary = await Api.GetMonthlySummaryAsync(SelectedMonth);
    }

    private decimal GetSalary(PersonResponse person)
    {
        var monthlySalary = person.Salaries
            .Where(s => s.Date.Year == SelectedMonth.Year && s.Date.Month == SelectedMonth.Month)
            .Select(s => s.Amount)
            .FirstOrDefault();

        if (monthlySalary > 0)
            return monthlySalary;

        return person.Salaries
            .Where(s => s.Date <= SelectedMonth)
            .OrderByDescending(s => s.Date)
            .Select(s => s.Amount)
            .FirstOrDefault();
    }

    private decimal GetPersonalExpenses(Guid personId)
    {
        if (Summary is null) return 0;

        return Summary.Transactions
            .Where(t => t.PaidBy.Id == personId && (t.SplitType == SplitType.None || t.SplitParticipants.Count == 1))
            .Sum(t => t.Amount);
    }

    private decimal GetSharedExpenses(Guid personId)
    {
        if (Summary is null) return 0;

        return Summary.Transactions
            .Where(t => t.SplitParticipants.Any(p => p.Id == personId) && t.SplitType != SplitType.None && t.SplitParticipants.Count > 1)
            .Sum(t => t.Amount / t.SplitParticipants.Count);
    }
}
